# Environment file consumed by the systemd service.
# Place at /etc/tenants_back.env, mode 0640, owner root:tenants.
# Loaded by `EnvironmentFile=/etc/tenants_back.env` in gunicorn.service.

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=.example.com,example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://*.example.com
DJANGO_BEHIND_TLS_PROXY=1

# Same-origin in prod → CORS isn't needed. Keep it tight.
DJANGO_CORS_ALLOW_ALL=0
DJANGO_CORS_ALLOWED_ORIGINS=

DB_NAME=tenants_back
DB_USER=tenants_back
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=5432

GUNICORN_WORKERS=3
GUNICORN_LOG_LEVEL=info